{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "ddev",
  "title": "DDEV",
  "description": "This extension lets you access the DDEV projects on your machine and easily start, stop, and snapshot your projects.",
  "icon": "extension-icon.png",
  "author": "SuoweiHu",
  "platforms": [
    "macOS"
  ],
  "categories": [
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "mode": "view",
      "name": "show-projects",
      "title": "Show Projects",
      "description": "List all the available DDEV projects."
    }
  ],
  "tools": [],
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  },
  "dependencies": {
    "@raycast/api": "^1.103.0",
    "@raycast/utils": "^2.2.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.0.4",
    "@types/node": "22.19.17",
    "@types/react": "19.0.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2"
  }
}
